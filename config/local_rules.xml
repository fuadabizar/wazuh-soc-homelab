<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <rule id="60122" level="5">
    <if_sid>18107</if_sid>
    <field name="win.system.eventID">4625</field>
    <description>Logon Failure - Unknown user or bad password</description>
  </rule>

    <rule id="100500" level="10" frequency="5" timeframe="120">
    <if_matched_sid>60122</if_matched_sid>
    <description>Possible Brute Force Login Attempt Detected</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="100501" level="12" frequency="5" timeframe="300" ignore="60">
    <if_matched_sid>60122</if_matched_sid>
    <if_group>authentication_success</if_group>
    <field name="win.system.eventID">^4624$</field>
    <description>Successful Login After Multiple Failed Attempts</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>authentication_success,bruteforce_success,account_compromise,</group>
  </rule>

</group>